@model MetalPriceDashboard.Models.RatiosDashboardPageViewModel

@{
    ViewData["Title"] = "Metal Ratios Dashboard";

    var metalOrder = new[] { "XAU", "XAG", "XPT", "XPD" };

    var groupedCards = Model.Cards
        .GroupBy(x => x.BaseMetal)
        .OrderBy(g =>
        {
            var index = Array.IndexOf(metalOrder, g.Key);
            return index == -1 ? int.MaxValue : index;
        })
        .ToList();

    var periodOptions = new List<(string Value, string Text)>
    {
        ("WEEK", "Haftalık"),
        ("MONTH", "Aylık"),
        ("3MONTH", "3 Aylık"),
        ("6MONTH", "6 Aylık"),
        ("YEAR", "Yıllık"),
        ("2YEAR", "2 Yıllık"),
        ("3YEAR", "3 Yıllık"),
        ("5YEAR", "5 Yıllık")
    };

    var selectedPeriodText = periodOptions
        .FirstOrDefault(x => string.Equals(x.Value, Model.Filter?.PeriodType, StringComparison.OrdinalIgnoreCase))
        .Text;

    if (string.IsNullOrWhiteSpace(selectedPeriodText))
    {
        selectedPeriodText = "Aylık";
    }

    var baseMetals = Model.BaseMetals != null && Model.BaseMetals.Any()
        ? Model.BaseMetals
        : metalOrder.ToList();
}

<style>
    .ratios-page {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .ratios-summary {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 18px;
        box-shadow: 0 2px 10px rgba(0, 0, 0, .04);
    }

        .ratios-summary h2 {
            margin-bottom: 12px;
            font-size: 1.5rem;
            font-weight: 700;
        }

    .filter-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 18px;
        box-shadow: 0 2px 10px rgba(0, 0, 0, .04);
    }

    .metals-rows {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .metal-group {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        padding: 16px;
        box-shadow: 0 2px 10px rgba(0, 0, 0, .04);
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .metal-group-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid #eef2f7;
        padding-bottom: 10px;
        gap: 12px;
    }

    .metal-group-title {
        margin: 0;
        font-size: 1.2rem;
        font-weight: 800;
    }

    .metal-group-count {
        font-size: .8rem;
        color: #6b7280;
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        border-radius: 999px;
        padding: 4px 10px;
        font-weight: 600;
        white-space: nowrap;
    }

    .metal-ratios {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 16px;
        align-items: stretch;
    }

    @@media (max-width: 1400px) {
        .metal-ratios {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 768px) {
        .metal-ratios {
            grid-template-columns: 1fr;
        }
    }

    .ratio-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 16px;
        box-shadow: 0 2px 10px rgba(0, 0, 0, .04);
        display: flex;
        flex-direction: column;
        gap: 12px;
        min-width: 0;
        height: 100%;
    }

    .ratio-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    .ratio-title {
        margin: 0;
        font-size: 1rem;
        font-weight: 700;
    }

    .valuation-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: .75rem;
        font-weight: 700;
        border: 1px solid #d1d5db;
        background: #f9fafb;
        color: #374151;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .valuation-overvalued {
        background: rgba(220, 53, 69, .08);
        color: #b42318;
        border-color: rgba(220, 53, 69, .18);
    }

    .valuation-undervalued {
        background: rgba(25, 135, 84, .08);
        color: #027a48;
        border-color: rgba(25, 135, 84, .18);
    }

    .valuation-fair {
        background: rgba(108, 117, 125, .08);
        color: #495057;
        border-color: rgba(108, 117, 125, .18);
    }

    .ratio-main {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 12px;
    }

    .ratio-value {
        font-size: 1.6rem;
        font-weight: 800;
        line-height: 1;
    }

    .ratio-sub {
        font-size: .85rem;
        color: #6b7280;
        margin-top: 4px;
    }

    .ratio-trend {
        text-align: right;
        font-weight: 700;
        flex-shrink: 0;
    }

    .trend-up {
        color: #198754;
    }

    .trend-down {
        color: #dc3545;
    }

    .trend-flat {
        color: #6c757d;
    }

    .sparkline-box {
        height: 52px;
        border-radius: 12px;
        background: #f8fafc;
        padding: 6px;
    }

    .sparkline {
        width: 100%;
        height: 40px;
        display: block;
    }

    .ratio-stats {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px;
    }

    .stat-box {
        background: #f8fafc;
        border-radius: 12px;
        padding: 10px;
    }

    .stat-label {
        font-size: .75rem;
        color: #6b7280;
        margin-bottom: 4px;
    }

    .stat-value {
        font-weight: 700;
        font-size: .95rem;
    }

    .ratio-comment {
        background: #f9fafb;
        border-radius: 12px;
        padding: 12px;
        color: #374151;
        font-size: .92rem;
        line-height: 1.4;
    }

    .ratio-context-note {
        font-size: .8rem;
        color: #6b7280;
        margin-top: -4px;
    }
</style>

<div class="container mt-4">
    <div class="ratios-page">
        <div class="ratios-summary">
            <h2>Metal Ratios Dashboard</h2>

            @if (Model.SnapshotTime.HasValue)
            {
                <div><strong>Snapshot Time:</strong> @Model.SnapshotTime.Value.ToString("dd.MM.yyyy HH:mm:ss")</div>
            }

            @if (Model.CreatedAt.HasValue)
            {
                <div><strong>Created At:</strong> @Model.CreatedAt.Value.ToString("dd.MM.yyyy HH:mm:ss")</div>
            }
        </div>

        <div class="filter-card">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Base Metal</label>
                    <select name="BaseMetal" class="form-select">
                        <option value="">All</option>
                        @foreach (var metal in baseMetals)
                        {
                            if (string.Equals(Model.Filter.BaseMetal, metal, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@metal" selected>@metal</option>
                            }
                            else
                            {
                                <option value="@metal">@metal</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Period Type</label>
                    <select name="PeriodType" class="form-select">
                        @foreach (var option in periodOptions)
                        {
                            if (string.Equals(Model.Filter.PeriodType, option.Value, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@option.Value" selected>@option.Text</option>
                            }
                            else
                            {
                                <option value="@option.Value">@option.Text</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-4 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-primary">Apply</button>
                    <a asp-action="Ratios" class="btn btn-outline-secondary">Clear</a>
                </div>
            </form>
        </div>

        @if (!groupedCards.Any())
        {
            <div class="alert alert-warning mb-0">
                Ratio verisi bulunamadı.
            </div>
        }
        else
        {
            <div class="metals-rows">
                @foreach (var metalGroup in groupedCards)
                {
                    <div class="metal-group">
                        <div class="metal-group-header">
                            <h3 class="metal-group-title">@metalGroup.Key</h3>
                            <span class="metal-group-count">@metalGroup.Count() Ratio</span>
                        </div>

                        <div class="metal-ratios">
                            @foreach (var card in metalGroup.OrderBy(x => x.SortOrder))
                            {
                                var trendClass = card.Direction switch
                                {
                                    "up" => "trend-up",
                                    "down" => "trend-down",
                                    _ => "trend-flat"
                                };

                                var valuationClass = card.Valuation switch
                                {
                                    "Overvalued" => "valuation-overvalued",
                                    "Undervalued" => "valuation-undervalued",
                                    _ => "valuation-fair"
                                };

                                var isUsdPriceCard = string.Equals(card.QuoteMetal, "USD", StringComparison.OrdinalIgnoreCase);

                                <div class="ratio-card">
                                    <div class="ratio-card-header">
                                        <h4 class="ratio-title">@card.Title</h4>
                                        <span class="valuation-badge @valuationClass">@card.Valuation</span>
                                    </div>

                                    <div class="ratio-main">
                                        <div>
                                            <div class="ratio-value">
                                                @if (card.QuoteMetal == "USD")
                                                {
                                                    @Math.Truncate(card.CurrentValue).ToString("N0")
                                                }
                                                else
                                                {
                                                    @card.CurrentValue.ToString("N3")
                                                }
                                            </div>
                                            <div class="ratio-sub">@card.ValueLabel</div>
                                            <div class="ratio-context-note">
                                                @(isUsdPriceCard
                                                    ? $"{card.BaseMetal} için en güncel fiyat referansı"
                                                    : $"{card.BaseMetal} / {card.QuoteMetal} için en güncel oran referansı")
                                            </div>
                                        </div>

                                        <div class="ratio-trend @trendClass">
                                            <div>@card.DirectionArrow @card.Change.ToString("N4")</div>
                                            <div>(@card.ChangePercent.ToString("N2")%)</div>
                                            <div class="ratio-context-note">@selectedPeriodText ortalamasına göre fark</div>
                                        </div>
                                    </div>

                                    <div class="sparkline-box">
                                        <svg class="sparkline" viewBox="0 0 140 42" preserveAspectRatio="none">
                                            <polyline fill="none"
                                                      stroke="currentColor"
                                                      stroke-width="2"
                                                      class="@trendClass"
                                                      points="@card.SparklinePoints" />
                                        </svg>
                                    </div>

                                    <div class="ratio-context-note">
                                        Trend analizi: @selectedPeriodText
                                    </div>

                                    <div class="ratio-stats">
                                        <div class="stat-box">
                                            <div class="stat-label">@selectedPeriodText Previous</div>
                                            <div class="stat-value">
                                                @(
                                                    card.PreviousValue == null
                                                    ? "-"
                                                    : card.QuoteMetal == "USD"
                                                    ? Math.Truncate(card.PreviousValue.Value).ToString("N0")
                                                    : card.PreviousValue.Value.ToString("N4")
                                                    )
                                            </div>
                                        </div>

                                        <div class="stat-box">
                                            <div class="stat-label">@selectedPeriodText Avg</div>
                                            <div class="stat-value">
                                                @(
                                                    card.QuoteMetal == "USD"
                                                    ? Math.Truncate(card.Average).ToString("N0")
                                                    : card.Average.ToString("N4")
                                                    )
                                            </div>
                                        </div>
                                    </div>

                                    <div class="ratio-comment">
                                        @card.Interpretation
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>