@model RatesDashboardPageViewModel
@{
    ViewData["Title"] = "TCMB Rates Dashboard";

    var currencyCodes = Model.CurrencyCodes != null && Model.CurrencyCodes.Any()
        ? Model.CurrencyCodes
        : Model.Items
            .Select(x => x.CurrencyCode)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct()
            .OrderBy(x => x)
            .ToList();
}

<style>
    .table-scroll-top {
        overflow-x: auto;
        overflow-y: hidden;
        height: 18px;
        margin-bottom: 8px;
    }

    .table-scroll-top-inner {
        height: 1px;
    }

    .table-responsive {
        overflow-x: auto;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">TCMB Rates Dashboard</h1>
    <span class="text-muted">Toplam: @Model.Items.Count kayıt</span>
</div>

<div class="card shadow-sm filter-card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Currency Code</label>
                <select name="CurrencyCode" class="form-select">
                    <option value="">All</option>
                    @foreach (var code in currencyCodes)
                    {
                        if (Model.Filter.CurrencyCode == code)
                        {
                            <option value="@code" selected>@code</option>
                        }
                        else
                        {
                            <option value="@code">@code</option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label">Period Type</label>
                <select name="PeriodType" class="form-select">
                    <option value="">All</option>
                    @if (Model.Filter.PeriodType == "WEEK")
                    {
                        <option value="WEEK" selected>WEEK</option>
                    }
                    else
                    {
                        <option value="WEEK">WEEK</option>
                    }

                    @if (Model.Filter.PeriodType == "MONTH")
                    {
                        <option value="MONTH" selected>MONTH</option>
                    }
                    else
                    {
                        <option value="MONTH">MONTH</option>
                    }

                    @if (Model.Filter.PeriodType == "YEAR")
                    {
                        <option value="YEAR" selected>YEAR</option>
                    }
                    else
                    {
                        <option value="YEAR">YEAR</option>
                    }
                </select>
            </div>

            <div class="col-md-4 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-primary">Apply</button>
                <a asp-action="Rates" class="btn btn-outline-secondary">Clear</a>
            </div>
        </form>
    </div>
</div>

@if (Model.Items.Count > 0)
{
    var latest = Model.Items
        .OrderByDescending(x => x.PeriodStartDate)
        .ThenByDescending(x => x.PeriodTypeSort)
        .First();

    var selectedYear = latest.PeriodStartDate.Year;

    var yearlyItems = Model.Items
        .Where(x => x.PeriodStartDate.Year == selectedYear)
        .ToList();

    var forexBuyingYearMin = yearlyItems.Min(x => x.ForexBuyingMin);
    var forexBuyingYearMax = yearlyItems.Max(x => x.ForexBuyingMax);
    var forexBuyingYearAvg = yearlyItems.Average(x => (x.ForexBuyingMin + x.ForexBuyingMax) / 2m);

    var forexSellingYearMin = yearlyItems.Min(x => x.ForexSellingMin);
    var forexSellingYearMax = yearlyItems.Max(x => x.ForexSellingMax);
    var forexSellingYearAvg = yearlyItems.Average(x => (x.ForexSellingMin + x.ForexSellingMax) / 2m);

    var banknoteSellingYearMin = yearlyItems.Min(x => x.BanknoteSellingMin);
    var banknoteSellingYearMax = yearlyItems.Max(x => x.BanknoteSellingMax);
    var banknoteSellingYearAvg = yearlyItems.Average(x => (x.BanknoteSellingMin + x.BanknoteSellingMax) / 2m);

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm card-summary h-100">
                <div class="card-body">
                    <div class="text-muted">Summary Year</div>
                    <div class="fs-5 fw-bold">@selectedYear</div>
                    <div class="small text-muted mt-2">Latest Period: @latest.PeriodLabel</div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm card-summary h-100">
                <div class="card-body">
                    <div class="text-muted">Forex Buying</div>
                    <div class="small mt-2">Min: <span class="fw-bold">@forexBuyingYearMin?.ToString("N4")</span></div>
                    <div class="small">Max: <span class="fw-bold">@forexBuyingYearMax?.ToString("N4")</span></div>
                    <div class="small">Avg: <span class="fw-bold">@forexBuyingYearAvg?.ToString("N4")</span></div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm card-summary h-100">
                <div class="card-body">
                    <div class="text-muted">Forex Selling</div>
                    <div class="small mt-2">Min: <span class="fw-bold">@forexSellingYearMin?.ToString("N4")</span></div>
                    <div class="small">Max: <span class="fw-bold">@forexSellingYearMax?.ToString("N4")</span></div>
                    <div class="small">Avg: <span class="fw-bold">@forexSellingYearAvg?.ToString("N4")</span></div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm card-summary h-100">
                <div class="card-body">
                    <div class="text-muted">Banknote Selling</div>
                    <div class="small mt-2">Min: <span class="fw-bold">@banknoteSellingYearMin?.ToString("N4")</span></div>
                    <div class="small">Max: <span class="fw-bold">@banknoteSellingYearMax?.ToString("N4")</span></div>
                    <div class="small">Avg: <span class="fw-bold">@banknoteSellingYearAvg?.ToString("N4")</span></div>
                </div>
            </div>
        </div>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <div id="topScrollbar" class="table-scroll-top">
            <div id="topScrollbarInner" class="table-scroll-top-inner"></div>
        </div>

        <div id="tableContainer" class="table-responsive">
            <table id="ratesTable" class="table table-hover table-bordered align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>CurrencyCode</th>
                        <th>Unit</th>
                        <th>PeriodType</th>
                        <th>PeriodLabel</th>
                        <th>Start</th>
                        <th>End</th>
                       
                        <th>BanknoteBuyingMin</th>
                        <th>BanknoteBuyingMax</th>
                        <th>BanknoteSellingMin</th>
                        <th>BanknoteSellingMax</th>

                        <th>ForexBuyingMin</th>
                        <th>ForexBuyingMax</th>
                        <th>ForexSellingMin</th>
                        <th>ForexSellingMax</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.CurrencyCode</td>
                            <td>@item.Unit</td>
                            <td>@item.PeriodType</td>
                            <td>@item.PeriodLabel</td>
                            <td>@item.PeriodStartDate.ToString("yyyy-MM-dd")</td>
                            <td>@item.PeriodEndDate.ToString("yyyy-MM-dd")</td>
                           
                            <td>@item.BanknoteBuyingMin</td>
                            <td>@item.BanknoteBuyingMax</td>
                            <td>@item.BanknoteSellingMin</td>
                            <td>@item.BanknoteSellingMax</td>

                            <td>@item.ForexBuyingMin</td>
                            <td>@item.ForexBuyingMax</td>
                            <td>@item.ForexSellingMin</td>
                            <td>@item.ForexSellingMax</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    (function () {
        const topScrollbar = document.getElementById('topScrollbar');
        const topScrollbarInner = document.getElementById('topScrollbarInner');
        const tableContainer = document.getElementById('tableContainer');
        const ratesTable = document.getElementById('ratesTable');

        let syncingFromTop = false;
        let syncingFromBottom = false;

        function updateTopScrollbarWidth() {
            if (!ratesTable || !topScrollbarInner || !tableContainer) return;

            topScrollbarInner.style.width = ratesTable.scrollWidth + 'px';

            const needsScroll = ratesTable.scrollWidth > tableContainer.clientWidth;
            topScrollbar.style.display = needsScroll ? 'block' : 'none';
        }

        if (topScrollbar && tableContainer) {
            topScrollbar.addEventListener('scroll', function () {
                if (syncingFromBottom) {
                    syncingFromBottom = false;
                    return;
                }

                syncingFromTop = true;
                tableContainer.scrollLeft = topScrollbar.scrollLeft;
            });

            tableContainer.addEventListener('scroll', function () {
                if (syncingFromTop) {
                    syncingFromTop = false;
                    return;
                }

                syncingFromBottom = true;
                topScrollbar.scrollLeft = tableContainer.scrollLeft;
            });
        }

        window.addEventListener('load', updateTopScrollbarWidth);
        window.addEventListener('resize', updateTopScrollbarWidth);

        setTimeout(updateTopScrollbarWidth, 100);
    })();
</script>