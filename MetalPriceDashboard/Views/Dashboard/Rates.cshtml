@model RatesDashboardPageViewModel
@{
    ViewData["Title"] = "TCMB Rates Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">TCMB Rates Dashboard</h1>
    <span class="text-muted">Toplam: @Model.Items.Count kayıt</span>
</div>

<div class="card shadow-sm filter-card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Currency Code</label>
                <input type="text" name="CurrencyCode" value="@Model.Filter.CurrencyCode" class="form-control" placeholder="USD" />
            </div>

            <div class="col-md-4">
                <label class="form-label">Period Type</label>
                <select name="PeriodType" class="form-select">
                    <option value="">All</option>
                    <option value="WEEK" selected="@(Model.Filter.PeriodType == "WEEK")">WEEK</option>
                    <option value="MONTH" selected="@(Model.Filter.PeriodType == "MONTH")">MONTH</option>
                    <option value="YEAR" selected="@(Model.Filter.PeriodType == "YEAR")">YEAR</option>
                </select>
            </div>

            <div class="col-md-4 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-primary">Apply</button>
                <a asp-action="Rates" class="btn btn-outline-secondary">Clear</a>
            </div>
        </form>
    </div>
</div>

@if (Model.Items.Count > 0)
{
    var latest = Model.Items
        .OrderByDescending(x => x.PeriodStartDate)
        .ThenByDescending(x => x.PeriodTypeSort)
        .First();

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm card-summary">
                <div class="card-body">
                    <div class="text-muted">Latest Period</div>
                    <div class="fs-5 fw-bold">@latest.PeriodLabel</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm card-summary">
                <div class="card-body">
                    <div class="text-muted">Forex Buying</div>
                    <div class="fw-bold">@latest.ForexBuyingMin - @latest.ForexBuyingMax</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm card-summary">
                <div class="card-body">
                    <div class="text-muted">Forex Selling</div>
                    <div class="fw-bold">@latest.ForexSellingMin - @latest.ForexSellingMax</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm card-summary">
                <div class="card-body">
                    <div class="text-muted">Banknote Selling</div>
                    <div class="fw-bold">@latest.BanknoteSellingMin - @latest.BanknoteSellingMax</div>
                </div>
            </div>
        </div>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover table-bordered align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>CurrencyCode</th>
                        <th>Unit</th>
                        <th>PeriodType</th>
                        <th>PeriodLabel</th>
                        <th>Start</th>
                        <th>End</th>
                        <th>ForexBuyingMin</th>
                        <th>ForexBuyingMax</th>
                        <th>ForexSellingMin</th>
                        <th>ForexSellingMax</th>
                        <th>BanknoteBuyingMin</th>
                        <th>BanknoteBuyingMax</th>
                        <th>BanknoteSellingMin</th>
                        <th>BanknoteSellingMax</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.CurrencyCode</td>
                            <td>@item.Unit</td>
                            <td>@item.PeriodType</td>
                            <td>@item.PeriodLabel</td>
                            <td>@item.PeriodStartDate.ToString("yyyy-MM-dd")</td>
                            <td>@item.PeriodEndDate.ToString("yyyy-MM-dd")</td>
                            <td>@item.ForexBuyingMin</td>
                            <td>@item.ForexBuyingMax</td>
                            <td>@item.ForexSellingMin</td>
                            <td>@item.ForexSellingMax</td>
                            <td>@item.BanknoteBuyingMin</td>
                            <td>@item.BanknoteBuyingMax</td>
                            <td>@item.BanknoteSellingMin</td>
                            <td>@item.BanknoteSellingMax</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>