@model MetalDashboardPageViewModel
@{
    ViewData["Title"] = "Metal Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Metal Dashboard</h1>
    <span class="text-muted">Toplam: @Model.Items.Count kayıt</span>
</div>

<div class="card shadow-sm filter-card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Base Currency</label>
                <input type="text" name="BaseCurrency" value="@Model.Filter.BaseCurrency" class="form-control" placeholder="USD" />
            </div>

            <div class="col-md-3">
                <label class="form-label">Metal</label>
                <select name="Metal" class="form-select">
                    <option value="">All</option>
                    <option value="XAU" selected="@(Model.Filter.Metal == "XAU")">XAU</option>
                    <option value="XAG" selected="@(Model.Filter.Metal == "XAG")">XAG</option>
                    <option value="XPT" selected="@(Model.Filter.Metal == "XPT")">XPT</option>
                    <option value="XPD" selected="@(Model.Filter.Metal == "XPD")">XPD</option>
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Period Type</label>
                <select name="PeriodType" class="form-select">
                    <option value="">All</option>
                    <option value="WEEK" selected="@(Model.Filter.PeriodType == "WEEK")">WEEK</option>
                    <option value="MONTH" selected="@(Model.Filter.PeriodType == "MONTH")">MONTH</option>
                    <option value="YEAR" selected="@(Model.Filter.PeriodType == "YEAR")">YEAR</option>
                </select>
            </div>

            <div class="col-md-3 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-primary">Apply</button>
                <a asp-action="Metal" class="btn btn-outline-secondary">Clear</a>
            </div>
        </form>
    </div>
</div>

@if (Model.Items.Count > 0)
{
    var latest = Model.Items
        .OrderByDescending(x => x.PeriodStartDate)
        .ThenByDescending(x => x.PeriodTypeSort)
        .First();

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm card-summary">
                <div class="card-body">
                    <div class="text-muted">Latest Period</div>
                    <div class="fs-4 fw-bold">@latest.PeriodLabel</div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm card-summary">
                <div class="card-body">
                    <div class="text-muted">Min Price</div>
                    <div class="fs-4 fw-bold">@latest.MinPrice</div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm card-summary">
                <div class="card-body">
                    <div class="text-muted">Max Price</div>
                    <div class="fs-4 fw-bold">@latest.MaxPrice</div>
                </div>
            </div>
        </div>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover table-bordered align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>BaseCurrency</th>
                        <th>Metal</th>
                        <th>PeriodType</th>
                        <th>PeriodLabel</th>
                        <th>Start</th>
                        <th>End</th>
                        <th>MinPrice</th>
                        <th>MaxPrice</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.BaseCurrency</td>
                            <td>@item.Metal</td>
                            <td>@item.PeriodType</td>
                            <td>@item.PeriodLabel</td>
                            <td>@item.PeriodStartDate.ToString("yyyy-MM-dd")</td>
                            <td>@item.PeriodEndDate.ToString("yyyy-MM-dd")</td>
                            <td>@item.MinPrice</td>
                            <td>@item.MaxPrice</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>