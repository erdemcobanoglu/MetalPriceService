@model MetalPriceDashboard.Models.RatesDashboardPageViewModel

@{
    ViewData["Title"] = "Rates Dashboard";

    var currencyCodes = Model.CurrencyCodes != null && Model.CurrencyCodes.Any()
        ? Model.CurrencyCodes
        : Model.Cards
            .Select(x => x.CurrencyCode)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct()
            .ToList();

    var periodOptions = new List<(string Value, string Text)>
    {
        ("WEEK", "Haftalık"),
        ("MONTH", "Aylık"),
        ("3MONTH", "3 Aylık"),
        ("6MONTH", "6 Aylık"),
        ("YEAR", "Yıllık"),
        ("2YEAR", "2 Yıllık"),
        ("3YEAR", "3 Yıllık"),
        ("5YEAR", "5 Yıllık")
    };

    var selectedPeriodText = periodOptions
        .FirstOrDefault(x => string.Equals(x.Value, Model.Filter?.PeriodType, StringComparison.OrdinalIgnoreCase))
        .Text;

    if (string.IsNullOrWhiteSpace(selectedPeriodText))
    {
        selectedPeriodText = "Genel";
    }
}

<style>
    .rates-cards-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 16px;
        margin-bottom: 24px;
    }

    .rate-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 16px;
        box-shadow: 0 2px 10px rgba(0, 0, 0, .04);
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .rate-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    .rate-title {
        margin: 0;
        font-size: 1rem;
        font-weight: 700;
    }

    .valuation-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: .75rem;
        font-weight: 700;
        border: 1px solid #d1d5db;
        background: #f9fafb;
        color: #374151;
        white-space: nowrap;
    }

    .valuation-overvalued {
        background: rgba(220, 53, 69, .08);
        color: #b42318;
        border-color: rgba(220, 53, 69, .18);
    }

    .valuation-undervalued {
        background: rgba(25, 135, 84, .08);
        color: #027a48;
        border-color: rgba(25, 135, 84, .18);
    }

    .valuation-fair {
        background: rgba(108, 117, 125, .08);
        color: #495057;
        border-color: rgba(108, 117, 125, .18);
    }

    .rate-main {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 12px;
    }

    .rate-value {
        font-size: 1.8rem;
        font-weight: 800;
        line-height: 1;
    }

    .rate-sub {
        font-size: .85rem;
        color: #6b7280;
        margin-top: 4px;
    }

    .rate-trend {
        text-align: right;
        font-weight: 700;
    }

    .trend-up {
        color: #198754;
    }

    .trend-down {
        color: #dc3545;
    }

    .trend-flat {
        color: #6c757d;
    }

    .sparkline-box {
        height: 52px;
        border-radius: 12px;
        background: #f8fafc;
        padding: 6px;
    }

    .sparkline {
        width: 100%;
        height: 40px;
        display: block;
    }

    .rate-stats {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px;
    }

    .stat-box {
        background: #f8fafc;
        border-radius: 12px;
        padding: 10px;
    }

    .stat-label {
        font-size: .75rem;
        color: #6b7280;
        margin-bottom: 4px;
    }

    .stat-value {
        font-weight: 700;
        font-size: .95rem;
    }

    .rate-comment {
        background: #f9fafb;
        border-radius: 12px;
        padding: 12px;
        color: #374151;
        font-size: .92rem;
        line-height: 1.4;
    }

    .rate-context-note {
        font-size: .8rem;
        color: #6b7280;
        margin-top: -4px;
    }

    @@media (max-width: 992px) {
        .rates-cards-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 576px) {
        .rates-cards-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Rates Dashboard</h1>
    <span class="text-muted">Toplam: @(Model.Cards?.Count ?? 0) kayıt</span>
</div>

<div class="card shadow-sm filter-card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Currency Code</label>
                <select name="CurrencyCode" class="form-select">
                    <option value="">All</option>
                    @foreach (var code in currencyCodes)
                    {
                        if (string.Equals(Model.Filter.CurrencyCode, code, StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="@code" selected>@code</option>
                        }
                        else
                        {
                            <option value="@code">@code</option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label">Period Type</label>
                <select name="PeriodType" class="form-select">
                    <option value="">All</option>
                    @foreach (var option in periodOptions)
                    {
                        if (string.Equals(Model.Filter.PeriodType, option.Value, StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="@option.Value" selected>@option.Text</option>
                        }
                        else
                        {
                            <option value="@option.Value">@option.Text</option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-4 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-primary">Apply</button>
                <a asp-action="RatesV2" class="btn btn-outline-secondary">Clear</a>
            </div>
        </form>
    </div>
</div>

@if (Model.Cards != null && Model.Cards.Any())
{
    <div class="rates-cards-grid">
        @foreach (var card in Model.Cards)
        {
            var trendClass = card.Direction switch
            {
                "up" => "trend-up",
                "down" => "trend-down",
                _ => "trend-flat"
            };

            var valuationClass = card.Valuation switch
            {
                "Overvalued" => "valuation-overvalued",
                "Undervalued" => "valuation-undervalued",
                _ => "valuation-fair"
            };

            <div class="rate-card">
                <div class="rate-card-header">
                    <h3 class="rate-title">@card.Title</h3>
                    <span class="valuation-badge @valuationClass">@card.Valuation</span>
                </div>

                <div class="rate-main">
                    <div>
                        <div class="rate-value">@card.CurrentValue.ToString("N4")</div>
                        <div class="rate-sub">Current Monthly Reference</div>
                        <div class="rate-context-note">@card.MetricName için en güncel aylık referans</div>
                    </div>

                    <div class="rate-trend @trendClass">
                        <div>@card.DirectionArrow @card.Change.ToString("N4")</div>
                        <div>(@card.ChangePercent.ToString("N2")%)</div>
                        <div class="rate-context-note">@selectedPeriodText ortalamasına göre fark</div>
                    </div>
                </div>

                <div class="sparkline-box">
                    <svg class="sparkline" viewBox="0 0 140 42" preserveAspectRatio="none">
                        <polyline fill="none"
                                  stroke="currentColor"
                                  stroke-width="2"
                                  class="@trendClass"
                                  points="@card.SparklinePoints" />
                    </svg>
                </div>

                <div class="rate-context-note">
                    Trend analizi: @selectedPeriodText
                </div>

                <div class="rate-stats">
                    <div class="stat-box">
                        <div class="stat-label">@selectedPeriodText Previous</div>
                        <div class="stat-value">
                            @(card.PreviousValue?.ToString("N4") ?? "-")
                        </div>
                    </div>

                    <div class="stat-box">
                        <div class="stat-label">@selectedPeriodText Avg</div>
                        <div class="stat-value">@card.Average.ToString("N4")</div>
                    </div>
                </div>

                <div class="rate-comment">
                    @card.Interpretation
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-warning mb-0">
        Kayıt bulunamadı.
    </div>
}